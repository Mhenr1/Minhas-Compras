<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Minhas_Compras.View.EditarProduto"
             Title="EditarProduto">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Editar"  Clicked="ToolbarItem_Clicked_Editar"/>
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Spacing="10" Margin="10">
        <Label Text="Descrição do Produto:" />
        <Entry Text="{Binding Descricao}" x:Name="txt_descricao"/>

        <Label Text="Quantidade" />
        <Entry Text="{Binding Quantidade}"  x:Name="txt_quantidade"  Keyboard="Numeric"/>

        <Label Text="Preço unitário" />
        <Entry Text="{Binding Preco}"  x:Name="txt_preco"  Keyboard="Numeric"/>

        <Label Text="Categoria" />
        <Entry Text="{Binding Categoria}" x:Name="txt_categoria"  />
    </VerticalStackLayout>
</ContentPage>
        