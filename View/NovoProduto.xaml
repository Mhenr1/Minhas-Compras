<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Minhas_Compras.View.NovoProduto"
             Title="NovoProduto">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked_Salvar"/>
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Spacing="10" Margin="10">
        <Label Text="Descrição do Produto:" />
        <Entry Placeholder="Digite a descrição do produto" x:Name="txt_descricao"/>
        
        <Label Text="Quantidade" />
        <Entry Placeholder="Digite a quantidade"  x:Name="txt_quantidade"  Keyboard="Numeric"/>
        
        <Label Text="Preço unitário" />
        <Entry Placeholder="Digite o valor por unidade"  x:Name="txt_preco"  Keyboard="Numeric"/>

    </VerticalStackLayout>
</ContentPage>